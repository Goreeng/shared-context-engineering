root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.rs]
indent_style = space
indent_size = 4

[*.{ts,mjs,js,json,jsonc}]
indent_style = tab
tab_width = 2

[*.{sh,pkl,yml,yaml,nix}]
indent_style = space
indent_size = 2

[*.{toml,sql}]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.lock]
indent_style = unset
indent_size = unset
